{
  "name": "@validater/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "db:generate": "DOTENV_CONFIG_PATH=../../.env drizzle-kit generate",
    "db:migrate": "DOTENV_CONFIG_PATH=../../.env drizzle-kit migrate",
    "db:push": "DOTENV_CONFIG_PATH=../../.env drizzle-kit push",
    "db:studio": "DOTENV_CONFIG_PATH=../../.env drizzle-kit studio"
  },
  "dependencies": {
    "@validater/core": "workspace:*",
    "drizzle-orm": "^0.45.0",
    "pg": "^8.13.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
